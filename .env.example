# Copy to .env and adjust. Never commit .env.

# --- Local development (DEBUG defaults to True if unset) ---
# DEBUG=True
DJANGO_SECRET_KEY=django-insecure-change-me-in-production-use-env

# Comma-separated hosts (spaces around commas are trimmed)
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2

# --- PostgreSQL (production / staging) — Part 2 ---
# Leave DATABASE_URL unset to use SQLite (db.sqlite3) for local dev.
#
# Recommended if you only need a managed database: Neon (https://neon.tech) — free tier
# with limits. Dashboard → Connection details → copy URI → paste below. No Neon SDK
# required; Django uses this like any Postgres URL.
#
# Supabase / Railway / Render: same idea — paste the project connection string.
# Use postgresql:// or postgres://. Keep ?sslmode=require if the dashboard includes it.
#
# Examples (passwords URL-encoded if they contain special characters):
# DATABASE_URL=postgresql://USER:PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=require
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#
# Verify before migrate: python manage.py gso_db_check
# After first deploy: python manage.py migrate
# Optional: move data from SQLite with dumpdata/loaddata per model (see MAIN_SYSTEM_AND_DEPLOYMENT_PLAN.md).

# --- Production (set on the server) ---
# DEBUG=False
# DJANGO_SECRET_KEY=<strong random secret, e.g. openssl rand -hex 32>
# ALLOWED_HOSTS=your.school.edu,www.your.school.edu
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# USE_TLS_BEHIND_PROXY=True
# CSRF_TRUSTED_ORIGINS=https://your.school.edu,https://www.your.school.edu
# CORS_ALLOWED_ORIGINS=https://your.school.edu

# Optional
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# SMTP for forgot-password emails (when EMAIL_BACKEND is smtp)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@school.edu
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# DEFAULT_FROM_EMAIL=GSO System <your-email@school.edu>
# GSO_SITE_URL=https://your-school-domain.edu
# GSO_EMAIL_NOTIFICATIONS_ENABLED=True
# GSO_PASSWORD_RESET_OTP_EXP_MINUTES=10
# GSO_PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
# GSO_PASSWORD_RESET_OTP_RESEND_COOLDOWN_SECONDS=60
# GSO_BACKUP_DIR=/var/backups/gso
# GSO_BACKUP_KEEP=7
# GSO_APP_VERSION=1.0
